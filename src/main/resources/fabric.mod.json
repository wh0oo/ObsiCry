  "authors": ["wh0oo"],
  "contact": {
    "homepage": "https://github.com/wh0oo/ObsiCry",
    "issues": "https://github.com/wh0oo/ObsiCry/issues"
  },
  "license": "MIT",
  "icon": "assets/obsicry/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.example.obsicry.ObsiCryInitializer"
    ]
  },
  "mixins": [
    "obsicry.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.2",
    "java": ">=25",
    "fabric-api": "*"
  }
